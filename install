#!/bin/bash

export MAIN_DIR=$PWD

# =============================================
# Helper: colored output
# =============================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

info()    { echo -e "${CYAN}> $1${NC}"; }
success() { echo -e "${GREEN}> $1${NC}"; }
warn()    { echo -e "${YELLOW}> WARNING: $1${NC}"; }
error()   { echo -e "${RED}> ERROR: $1${NC}"; }

# =============================================
# Dependency Check
# =============================================
info "Checking required dependencies..."
MISSING_DEPS=()
for dep in curl wget tar jq screen; do
  if ! command -v $dep &>/dev/null; then
    MISSING_DEPS+=($dep)
  fi
done

if [ ${#MISSING_DEPS[@]} -gt 0 ]; then
  warn "The following dependencies are missing: ${MISSING_DEPS[*]}"
  info "Attempting to install them..."
  sudo apt-get install -y -qq "${MISSING_DEPS[@]}"
  if [ $? -ne 0 ]; then
    error "Failed to install dependencies. Please install them manually and re-run."
    exit 1
  fi
  success "Dependencies installed successfully!"
else
  success "All dependencies are present."
fi

# =============================================
# Server Type Selection (with validation)
# =============================================
echo ""
echo "Which Server do you want to install?"
echo "  [1] Java Server"
echo "  [2] Bedrock Server"
echo ""

while true; do
  read -rp "Enter choice [1-2]: " choiceForServer
  case "$choiceForServer" in
    1|2) break ;;
    *) error "Invalid choice '$choiceForServer'. Please enter 1 or 2." ;;
  esac
done

# =============================================
# Java Selection and Download
# =============================================
if [[ "$choiceForServer" == "1" ]]; then
  echo ""
  info "Which Java version do you need?"
  echo "  [1] Java 17  (Minecraft 1.17 - 1.20.4)"
  echo "  [2] Java 21  (Minecraft 1.20.5+, recommended)"
  echo ""

  while true; do
    read -rp "Enter choice [1-2]: " javaChoice
    case "$javaChoice" in
      1|2) break ;;
      *) error "Invalid choice. Please enter 1 or 2." ;;
    esac
  done

  mkdir -p bin

  if [[ "$javaChoice" == "1" ]]; then
    JAVA_URL="https://download.java.net/java/GA/jdk17.0.2/dfd4a8d0985749f896bed50d7138ee7f/8/GPL/openjdk-17.0.2_linux-x64_bin.tar.gz"
    JAVA_DIR="jdk-17.0.2"
    info "Downloading Java 17..."
  else
    JAVA_URL="https://download.java.net/java/GA/jdk21.0.2/f2283984656d49d69e91c558476027ac/13/GPL/openjdk-21.0.2_linux-x64_bin.tar.gz"
    JAVA_DIR="jdk-21.0.2"
    info "Downloading Java 21..."
  fi

  wget -q "$JAVA_URL" -O bin/java.tar.gz
  if [ $? -ne 0 ]; then
    error "Failed to download Java. Check your internet connection and try again."
    exit 1
  fi

  info "Extracting Java to bin/ folder... (this may take a moment)"
  rm -rf bin/java_bins 2>/dev/null
  tar -xf bin/java.tar.gz -C bin/ && mv "bin/$JAVA_DIR" bin/java_bins
  if [ $? -ne 0 ]; then
    error "Failed to extract Java."
    exit 1
  fi
  rm -f bin/java.tar.gz
  success "Java installed successfully at bin/java_bins!"

else
  # Bedrock doesn't need Java
  mkdir -p bin
fi

# =============================================
# Run the appropriate installer
# =============================================
chmod +x installJava installBedrock startserver stopserver startJavaServer startBedrockServer startPlayIt startAfk uninstall update backup .checkserver 2>/dev/null
chmod +x JavaInstallScripts/* BedrockInstallScripts/* 2>/dev/null

if [[ "$choiceForServer" == "1" ]]; then
  info "Running Java Installation..."
  ./installJava
elif [[ "$choiceForServer" == "2" ]]; then
  info "Running Bedrock Installation..."
  ./installBedrock
fi

info "AFK/Keep-Alive heartbeat is built-in. bpytop is optional."

echo ""
success "Installation process complete!"
